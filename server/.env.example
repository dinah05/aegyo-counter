# 카운터 리셋 비밀번호 (리셋 API 호출 시 필요)
COUNTER_RESET_PASSWORD=change-me

# Discord 웹훅 알림
# enabled=true 이고 URL이 있으면 실제 전송, 아니면 로그로 대체
DISCORD_WEBHOOK_ENABLED=false
DISCORD_WEBHOOK_URL=
# count가 이 값을 넘어서는 순간 알림 전송 (기본 50)
NOTIFICATION_THRESHOLD=50

# 운영(prod) 프로파일 PostgreSQL (Railway 등)
# SPRING_PROFILES_ACTIVE=prod
# PGHOST=
# PGPORT=5432
# PGDATABASE=
# PGUSER=
# PGPASSWORD=
